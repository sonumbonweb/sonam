<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Progress Quest — A Life in Progress</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=MedievalSharp&family=IM+Fell+English:ital@0;1&family=Share+Tech+Mono&display=swap');

    :root {
      --bg:        #0a0c0e;
      --panel:     #0f1318;
      --border:    #2a3a2a;
      --gold:      #c8a84b;
      --gold-dim:  #7a6230;
      --green:     #3ddc84;
      --green-dim: #1a5c3a;
      --red:       #d64545;
      --blue:      #4a9eff;
      --text:      #b8c8b0;
      --text-dim:  #5a6a52;
      --xp-bar:    #2a4a1a;
      --xp-fill:   #5ada28;
      --hp-fill:   #da2828;
      --mp-fill:   #284ada;
      --sidebar-w: 220px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Share Tech Mono', monospace;
      font-size: 13px;
      min-height: 100vh;
      display: flex;
      overflow: hidden;
      image-rendering: pixelated;
    }

    /* ── SCANLINE OVERLAY ── */
    body::after {
      content: '';
      position: fixed; inset: 0;
      pointer-events: none;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,0,0,.15) 2px,
        rgba(0,0,0,.15) 4px
      );
      z-index: 9999;
    }

    /* ── SIDEBAR ── */
    #sidebar {
      width: var(--sidebar-w);
      min-width: var(--sidebar-w);
      background: var(--panel);
      border-right: 2px solid var(--border);
      display: flex;
      flex-direction: column;
      overflow: hidden;
      position: relative;
    }

    .sidebar-header {
      padding: 14px 12px 10px;
      border-bottom: 1px solid var(--border);
    }

    .char-name {
      font-family: 'IM Fell English', serif;
      font-size: 17px;
      color: var(--gold);
      letter-spacing: .04em;
      text-shadow: 0 0 12px rgba(200,168,75,.5);
    }

    .char-class {
      font-size: 11px;
      color: var(--text-dim);
      margin-top: 2px;
    }

    .char-stats {
      padding: 10px 12px;
      border-bottom: 1px solid var(--border);
    }

    .stat-bar-row {
      display: flex;
      align-items: center;
      gap: 6px;
      margin-bottom: 5px;
    }

    .stat-label {
      width: 22px;
      font-size: 10px;
      color: var(--text-dim);
      flex-shrink: 0;
    }

    .bar-track {
      flex: 1;
      height: 8px;
      background: #111;
      border: 1px solid #222;
      position: relative;
      overflow: hidden;
    }

    .bar-fill {
      height: 100%;
      transition: width .4s ease;
      position: relative;
    }

    .bar-fill::after {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: rgba(255,255,255,.25);
    }

    .hp-bar  { background: var(--hp-fill);  width: 87%; }
    .mp-bar  { background: var(--mp-fill);  width: 64%; }
    .xp-bar  { background: var(--xp-fill);  width: 43%; animation: xp-pulse 3s ease-in-out infinite; }

    @keyframes xp-pulse {
      0%,100% { filter: brightness(1); }
      50%      { filter: brightness(1.3); }
    }

    .stat-val { font-size: 10px; color: var(--text-dim); width: 30px; text-align: right; }

    /* ── NAV ── */
    nav { flex: 1; padding: 8px 0; overflow-y: auto; }

    nav::-webkit-scrollbar { width: 4px; }
    nav::-webkit-scrollbar-thumb { background: var(--border); }

    .nav-section {
      font-size: 9px;
      color: var(--gold-dim);
      text-transform: uppercase;
      letter-spacing: .1em;
      padding: 8px 14px 4px;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 7px 14px;
      cursor: pointer;
      color: var(--text-dim);
      transition: all .15s;
      position: relative;
      border-left: 2px solid transparent;
      user-select: none;
    }

    .nav-item:hover {
      background: rgba(61,220,132,.05);
      color: var(--text);
      border-left-color: var(--green-dim);
    }

    .nav-item.active {
      background: rgba(61,220,132,.08);
      color: var(--green);
      border-left-color: var(--green);
    }

    .nav-item.active .nav-icon { filter: drop-shadow(0 0 4px var(--green)); }

    .nav-icon { font-size: 14px; flex-shrink: 0; }
    .nav-label { font-size: 12px; }
    .nav-badge {
      margin-left: auto;
      font-size: 9px;
      background: var(--green-dim);
      color: var(--green);
      border-radius: 2px;
      padding: 1px 4px;
    }

    /* ── QUEST LOG (bottom of sidebar) ── */
    .quest-log {
      padding: 10px 12px;
      border-top: 1px solid var(--border);
      font-size: 10px;
      color: var(--text-dim);
      max-height: 110px;
      overflow: hidden;
    }

    .quest-log-title {
      color: var(--gold-dim);
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: .1em;
      margin-bottom: 4px;
    }

    .quest-line {
      padding: 2px 0;
      opacity: 0;
      animation: fadeIn .4s forwards;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    @keyframes fadeIn { to { opacity: 1; } }

    /* ── MAIN CONTENT ── */
    #main {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ── TOP BAR ── */
    .topbar {
      height: 32px;
      background: var(--panel);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 16px;
      gap: 14px;
      flex-shrink: 0;
    }

    .topbar-title {
      font-family: 'IM Fell English', serif;
      color: var(--gold);
      font-size: 14px;
      letter-spacing: .05em;
      text-shadow: 0 0 10px rgba(200,168,75,.4);
    }

    .topbar-sep { color: var(--border); }

    .topbar-breadcrumb { color: var(--text-dim); font-size: 11px; }

    .topbar-right {
      margin-left: auto;
      display: flex;
      gap: 16px;
      align-items: center;
      font-size: 11px;
      color: var(--text-dim);
    }

    .blink { animation: blink 1.2s step-end infinite; }
    @keyframes blink { 50% { opacity: 0; } }

    /* ── PAGE WRAPPER ── */
    .page-content {
      flex: 1;
      overflow-y: auto;
      padding: 24px;
      position: relative;
    }

    .page-content::-webkit-scrollbar { width: 6px; }
    .page-content::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

    .page { display: none; }
    .page.active { display: block; }

    /* ── WINDOW PANELS ── */
    .win {
      background: var(--panel);
      border: 1px solid var(--border);
      margin-bottom: 16px;
      position: relative;
    }

    .win::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--gold-dim), transparent);
    }

    .win-title-bar {
      background: linear-gradient(90deg, #1a2a1a, #0f1a0f);
      border-bottom: 1px solid var(--border);
      padding: 5px 12px;
      font-size: 11px;
      color: var(--gold);
      display: flex;
      align-items: center;
      gap: 8px;
      letter-spacing: .05em;
    }

    .win-dots {
      display: flex; gap: 4px;
    }

    .win-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
    }

    .d1 { background: #444; }
    .d2 { background: #444; }
    .d3 { background: var(--gold-dim); }

    .win-body { padding: 14px 16px; }

    /* ── HOME PAGE: ZERO PLAYER GAME ── */
    #home-game {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    @media (max-width: 700px) {
      #home-game { grid-template-columns: 1fr; }
    }

    .game-log {
      font-size: 11px;
      line-height: 1.7;
      min-height: 120px;
      max-height: 180px;
      overflow-y: auto;
      color: var(--text);
    }

    .game-log::-webkit-scrollbar { width: 4px; }
    .game-log::-webkit-scrollbar-thumb { background: var(--border); }

    .log-entry { margin-bottom: 3px; }
    .log-ts { color: var(--text-dim); margin-right: 6px; }
    .log-good  { color: var(--green); }
    .log-bad   { color: var(--red); }
    .log-gold  { color: var(--gold); }
    .log-info  { color: var(--blue); }

    .task-section { margin-top: 10px; }

    .task-label {
      font-size: 10px;
      color: var(--text-dim);
      margin-bottom: 4px;
      text-transform: uppercase;
      letter-spacing: .08em;
    }

    .task-name {
      font-size: 12px;
      color: var(--gold);
      margin-bottom: 6px;
      font-family: 'IM Fell English', serif;
      font-style: italic;
    }

    .progress-track {
      background: #0a0a0a;
      border: 1px solid var(--border);
      height: 14px;
      position: relative;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--xp-bar), var(--xp-fill));
      transition: width .3s linear;
      position: relative;
    }

    .progress-fill::after {
      content: '';
      position: absolute;
      top: 0; right: 0;
      width: 3px; height: 100%;
      background: rgba(255,255,255,.5);
      filter: blur(2px);
    }

    .progress-text {
      position: absolute;
      right: 6px; top: 0; bottom: 0;
      display: flex; align-items: center;
      font-size: 9px;
      color: rgba(255,255,255,.5);
    }

    .attributes-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px 14px;
      font-size: 11px;
    }

    .attr-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 3px 0;
      border-bottom: 1px solid rgba(42,58,42,.4);
    }

    .attr-name { color: var(--text-dim); }
    .attr-val  { color: var(--gold); font-size: 12px; }

    .inventory-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
    }

    .inv-slot {
      aspect-ratio: 1;
      background: #0a0a0a;
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      cursor: default;
      position: relative;
      transition: border-color .2s;
    }

    .inv-slot:hover { border-color: var(--gold-dim); }
    .inv-slot.empty { opacity: .3; }

    .inv-slot-label {
      position: absolute;
      bottom: 2px; right: 3px;
      font-size: 7px;
      color: var(--gold-dim);
    }

    .spells-list { display: flex; flex-direction: column; gap: 6px; }

    .spell-row {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 5px 8px;
      background: rgba(0,0,0,.3);
      border: 1px solid transparent;
      cursor: default;
      transition: border-color .2s;
    }

    .spell-row:hover { border-color: var(--blue); }
    .spell-icon { font-size: 16px; }
    .spell-name { flex: 1; color: var(--text); font-size: 11px; }
    .spell-cost { color: var(--blue); font-size: 10px; }

    /* ── ABOUT ── */
    .about-hero {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 20px;
      align-items: start;
    }

    .char-portrait {
      width: 90px; height: 90px;
      background: #0a0a0a;
      border: 2px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 52px;
      position: relative;
      flex-shrink: 0;
    }

    .char-portrait::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(200,168,75,.1) 0%, transparent 60%);
    }

    .lore-text {
      font-family: 'IM Fell English', serif;
      font-size: 14px;
      line-height: 1.8;
      color: var(--text);
    }

    .lore-text em { color: var(--gold); font-style: normal; }

    .level-badge {
      display: inline-block;
      background: var(--green-dim);
      color: var(--green);
      border: 1px solid var(--green);
      padding: 2px 8px;
      font-size: 10px;
      margin-top: 8px;
      letter-spacing: .1em;
    }

    /* ── PROJECTS ── */
    .project-card {
      border: 1px solid var(--border);
      padding: 14px;
      margin-bottom: 10px;
      background: #0a0c0a;
      position: relative;
      transition: border-color .2s;
      cursor: pointer;
    }

    .project-card:hover { border-color: var(--gold-dim); }

    .project-card::before {
      content: attr(data-status);
      position: absolute;
      top: 10px; right: 12px;
      font-size: 9px;
      padding: 2px 6px;
      text-transform: uppercase;
      letter-spacing: .1em;
    }

    .project-card[data-status="Active"]::before  { color: var(--green); background: rgba(61,220,132,.1); border: 1px solid var(--green-dim); }
    .project-card[data-status="Brewing"]::before { color: var(--gold);  background: rgba(200,168,75,.1); border: 1px solid var(--gold-dim); }
    .project-card[data-status="Done"]::before    { color: var(--text-dim); background: rgba(90,90,90,.1); border: 1px solid #333; }

    .proj-title {
      font-family: 'IM Fell English', serif;
      font-size: 15px;
      color: var(--gold);
      margin-bottom: 5px;
    }

    .proj-desc { font-size: 11px; color: var(--text-dim); line-height: 1.6; max-width: 80%; }

    .proj-tags { display: flex; gap: 6px; margin-top: 8px; flex-wrap: wrap; }

    .tag {
      font-size: 9px;
      padding: 2px 6px;
      border: 1px solid #333;
      color: #555;
      letter-spacing: .05em;
    }

    /* ── BOOKSTACK ── */
    .book-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
      gap: 10px;
    }

    .book-card {
      background: #0a0a0a;
      border: 1px solid var(--border);
      padding: 12px;
      cursor: pointer;
      transition: border-color .2s;
    }

    .book-card:hover { border-color: var(--gold-dim); }

    .book-spine {
      width: 100%;
      height: 8px;
      margin-bottom: 8px;
      border-radius: 1px;
    }

    .book-title {
      font-family: 'IM Fell English', serif;
      font-size: 12px;
      color: var(--text);
      line-height: 1.4;
      margin-bottom: 4px;
    }

    .book-author { font-size: 10px; color: var(--text-dim); }

    .book-status {
      margin-top: 6px;
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: .08em;
    }

    /* ── BLOG PAGES ── */
    .post-entry {
      border-bottom: 1px solid var(--border);
      padding: 16px 0;
    }

    .post-entry:last-child { border-bottom: none; }

    .post-date {
      font-size: 10px;
      color: var(--text-dim);
      margin-bottom: 4px;
      letter-spacing: .05em;
    }

    .post-title {
      font-family: 'IM Fell English', serif;
      font-size: 17px;
      color: var(--gold);
      cursor: pointer;
      transition: color .2s;
    }

    .post-title:hover { color: var(--green); }

    .post-excerpt {
      font-size: 12px;
      color: var(--text-dim);
      line-height: 1.7;
      margin-top: 6px;
      font-style: italic;
    }

    .post-tags { margin-top: 8px; display: flex; gap: 5px; }

    /* ── CONTACT ── */
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .contact-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 12px;
      background: #0a0a0a;
      border: 1px solid var(--border);
      cursor: pointer;
      transition: border-color .2s;
      text-decoration: none;
    }

    .contact-item:hover { border-color: var(--gold-dim); }
    .contact-icon { font-size: 20px; }
    .contact-label { font-size: 11px; color: var(--text-dim); }
    .contact-val   { font-size: 12px; color: var(--text); }

    /* ── STATUS BAR ── */
    .statusbar {
      height: 22px;
      background: #07090a;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 0 16px;
      gap: 20px;
      font-size: 10px;
      color: var(--text-dim);
      flex-shrink: 0;
    }

    .status-item { display: flex; gap: 5px; align-items: center; }
    .status-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--green);
      animation: pulse-dot 2s ease-in-out infinite;
    }

    @keyframes pulse-dot {
      0%,100% { opacity: 1; }
      50%      { opacity: .3; }
    }

    /* ── SCROLLABLE TEXT STYLES ── */
    .prose {
      font-family: 'IM Fell English', serif;
      font-size: 14px;
      line-height: 1.9;
      color: var(--text);
      max-width: 680px;
    }

    .prose p { margin-bottom: 12px; }
    .prose em { color: var(--gold); font-style: italic; }

    /* ── HELPER ── */
    .mt8  { margin-top: 8px; }
    .mt14 { margin-top: 14px; }
    .section-divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 16px 0;
    }

    /* ── TRAVELOGUE ── */
    .travel-entry {
      display: grid;
      grid-template-columns: 60px 1fr;
      gap: 14px;
      padding: 14px 0;
      border-bottom: 1px solid var(--border);
    }

    .travel-coord {
      font-size: 10px;
      color: var(--text-dim);
      text-align: center;
      padding-top: 4px;
    }

    .travel-flag { font-size: 28px; text-align: center; }

    .travel-title {
      font-family: 'IM Fell English', serif;
      font-size: 16px;
      color: var(--gold);
    }

    .travel-meta { font-size: 10px; color: var(--text-dim); margin: 3px 0 6px; }
    .travel-excerpt { font-size: 12px; color: var(--text-dim); line-height: 1.6; font-style: italic; }

    /* ── LETTER ── */
    .letter-entry {
      padding: 14px 18px;
      border-left: 3px solid var(--gold-dim);
      margin-bottom: 14px;
      background: rgba(200,168,75,.03);
    }

    .letter-num { font-size: 10px; color: var(--gold-dim); letter-spacing: .1em; text-transform: uppercase; }

    .letter-subject {
      font-family: 'IM Fell English', serif;
      font-size: 16px;
      color: var(--gold);
      margin: 3px 0 6px;
    }

    .letter-open { font-size: 12px; color: var(--text-dim); line-height: 1.7; font-style: italic; }

    /* ── TOOLTIP ── */
    [title] { cursor: help; }

    /* ── CORNER DECORATION ── */
    .corner-deco {
      position: absolute;
      width: 12px; height: 12px;
      border-color: var(--gold-dim);
      border-style: solid;
    }

    .corner-deco.tl { top: -1px; left: -1px; border-width: 2px 0 0 2px; }
    .corner-deco.tr { top: -1px; right: -1px; border-width: 2px 2px 0 0; }
    .corner-deco.bl { bottom: -1px; left: -1px; border-width: 0 0 2px 2px; }
    .corner-deco.br { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; }
  </style>
</head>
<body>

<!-- ═══════════════════════ SIDEBAR ═══════════════════════ -->
<aside id="sidebar">
  <div class="sidebar-header">
    <div class="char-name">Adventurer</div>
    <div class="char-class">Lvl 27 · Curious Wanderer</div>
  </div>

  <div class="char-stats">
    <div class="stat-bar-row">
      <span class="stat-label">HP</span>
      <div class="bar-track"><div class="bar-fill hp-bar"></div></div>
      <span class="stat-val">174/200</span>
    </div>
    <div class="stat-bar-row">
      <span class="stat-label">MP</span>
      <div class="bar-track"><div class="bar-fill mp-bar"></div></div>
      <span class="stat-val">96/150</span>
    </div>
    <div class="stat-bar-row">
      <span class="stat-label">XP</span>
      <div class="bar-track"><div class="bar-fill xp-bar" id="xp-bar-fill"></div></div>
      <span class="stat-val" id="xp-text">43%</span>
    </div>
  </div>

  <nav id="nav">
    <div class="nav-section">Realms</div>
    <div class="nav-item active" data-page="home">
      <span class="nav-icon">⚔️</span>
      <span class="nav-label">Home</span>
      <span class="nav-badge">LIVE</span>
    </div>
    <div class="nav-item" data-page="about">
      <span class="nav-icon">📜</span>
      <span class="nav-label">About</span>
    </div>
    <div class="nav-item" data-page="projects">
      <span class="nav-icon">🏗️</span>
      <span class="nav-label">Projects</span>
    </div>
    <div class="nav-item" data-page="bookstack">
      <span class="nav-icon">📚</span>
      <span class="nav-label">Bookstack</span>
    </div>
    <div class="nav-section">Chronicles</div>
    <div class="nav-item" data-page="fascinations">
      <span class="nav-icon">🔮</span>
      <span class="nav-label">LifeFascinations</span>
    </div>
    <div class="nav-item" data-page="letters">
      <span class="nav-icon">✉️</span>
      <span class="nav-label">Letters to Father</span>
    </div>
