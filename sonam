/* ── ZERO PLAYER GAME LOOP ── */
function pick(arr) { return arr[Math.floor(Math.random()*arr.length)]; }

function addLogEntry(text, cls) {
  const log = document.getElementById('action-log');
  if (!log) return;
  const now = new Date();
  const ts = `${String(now.getHours()).padStart(2,'0')}:${String(now.getMinutes()).padStart(2,'0')}`;
  const div = document.createElement('div');
  div.className = `log-entry ${cls}`;
  div.innerHTML = `<span class="log-ts">[${ts}]</span>${text}`;
  log.appendChild(div);
  while (log.children.length > 40) log.removeChild(log.firstChild);
  log.scrollTop = log.scrollHeight;
}

function gameStep() {
  taskProgress += Math.random() * 12 + 3;
  if (taskProgress >= 100) {
    taskProgress = 0;
    taskIndex = (taskIndex + 1) % TASKS.length;
    document.getElementById('task-name').textContent = TASKS[taskIndex];

    // trigger an action
    const [verb, targets] = pick(ACTIONS);
    const target = pick(targets);
    const cls = pick(LOG_TYPES);
    addLogEntry(`${verb} ${target}`, cls);

    if (verb === "Slaying") { kills++; document.getElementById('kill-count').textContent = kills; }
    if (verb === "Looting") { gold += Math.floor(Math.random()*10)+1; document.getElementById('gold-count').textContent = gold; }

    // xp tick
    xp = Math.min(99, xp + Math.floor(Math.random()*3)+1);
    if (xp >= 99) xp = 0;
    document.getElementById('xp-bar-fill').style.width = xp + '%';
    document.getElementById('xp-text').textContent = xp + '%';
    document.getElementById('life-xp-bar').style.width = xp + '%';
  }

  const pct = Math.round(taskProgress);
  document.getElementById('task-bar').style.width = pct + '%';
  document.getElementById('task-pct').textContent = pct + '%';
}

/* ── CLOCK ── */
function updateClock() {
  const n = new Date();
  document.getElementById('clock-display').textContent =
    [n.getHours(),n.getMinutes(),n.getSeconds()].map(v=>String(v).padStart(2,'0')).join(':');
}

/* ── QUEST LINES ── */
function populateQuestLines() {
  const el = document.getElementById('quest-lines');
  QUEST_LINES.forEach((q,i) => {
    const d = document.createElement('div');
    d.className = 'quest-line';
    d.style.animationDelay = (i*0.3)+'s';
    d.textContent = q;
    el.appendChild(d);
  });
}

