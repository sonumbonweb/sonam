setTimeout(()=>addLogEntry('Character loaded. Adventure resumed.','log-good'), 400);
setTimeout(()=>addLogEntry('All systems nominal.','log-info'), 900);
setTimeout(()=>addLogEntry('Passive skills active.','log-info'), 1400);

document.getElementById('task-name').textContent = TASKS[0];

setInterval(gameStep, 1200);
setInterval(updateClock, 1000);
updateClock();
</script>
